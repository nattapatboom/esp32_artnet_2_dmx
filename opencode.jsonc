{
  "$schema": "https://opencode.ai",
  "mcp": {
    "serena": {
      "type": "local",
      "command": ["uvx", "-p", "3.13", "--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--context", "ide-assistant", "--transport", "stdio", "--project-from-cwd"],
      "enabled": true,
      "timeout": 15000
    },
    "platformio": {
      "type": "local",
      "command": ["npx", "-y", "platformio-mcp"],
      "enabled": true,
      "timeout": 30000
    },
    "git": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-git"],
      "enabled": true,
      "timeout": 15000
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
      "timeout": 15000
    }
  }
}
